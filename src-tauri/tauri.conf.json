{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Lumora",
  "version": "0.1.0",
  "identifier": "com.lumora.widget",

  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173/",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },

  "app": {
    "windows": [
      {
        "title": "Lumora",

        "width": 320,
        "height": 420,

        "center": true,

        "resizable": false,

        "fullscreen": false,

        "decorations": false,

        "transparent": true,
        
        "alwaysOnTop": true,

        "shadow": true
      }
    ],

    "security": {
      "csp": null
    }
  },

  "bundle": {
    "active": true,

    "targets": "all",

    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],

    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}